{
  "name": "analisador-lexico-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "npm run build-lexer",
    "prestart:dev": "npm run build-lexer",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build-lexer": "cmd /c ..\\build\\build-lexer.bat"
  },
  "dependencies": {
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.5",
    "@types/node": "^18.0.0"
  }
}
